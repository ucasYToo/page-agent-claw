{
  "name": "page-agent-claw",
  "version": "1.0.0",
  "description": "Page Agent Dashboard - CLI tool to start the dashboard server",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "page-agent-claw": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "tsc --project tsconfig.json",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["page-agent", "dashboard", "cli"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
